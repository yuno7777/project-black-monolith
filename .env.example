# The variables the Compose stack requires. This file documents their names —
# it deliberately carries no values, not even placeholder ones: a dummy value
# shaped like a password ("replace-with-...") is indistinguishable from a real
# one to a secret scanner, and training yourself to dismiss those alerts is how
# a genuine leak gets waved through.
#
# Generate a real .env (gitignored) with:
#
#   bash scripts/generate_secrets.sh
#
# which writes 24 bytes of CSPRNG output per value. Compose fails loudly with
# the variable's name if any of these is unset, so an empty value here cannot
# silently become a weak credential.

# Postgres superuser password for the ledger database.
# Note: baked in at first volume init — changing it later has no effect unless
# you drop the volume (docker compose down -v).
MONOLITH_POSTGRES_PASSWORD=

# Per-module ingest bearer tokens. Each is scoped to one module, so one
# module's credential cannot be used to forge another's events.
MONOLITH_EVENT_TOKEN_MCP_SHIELD=
MONOLITH_EVENT_TOKEN_VECTOR_ANCHOR=
MONOLITH_EVENT_TOKEN_TRACE_AUDIT=
